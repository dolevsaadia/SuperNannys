# Server
NODE_ENV=development
PORT=8080
CLIENT_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://supernanny:supernanny_secret@localhost:5432/supernanny_db?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=14d
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth — all three IDs from Firebase console
# Web client ID (type 3) — used by backend to verify tokens
GOOGLE_CLIENT_ID=768121322557-to3kut5fj1l82l0scnrebqs614qvb2dr.apps.googleusercontent.com
# iOS client ID (type 2)
GOOGLE_IOS_CLIENT_ID=768121322557-3reccv7capojqi11t3an73eir4178fc6.apps.googleusercontent.com
# Android client ID (type 1)
GOOGLE_ANDROID_CLIENT_ID=768121322557-gs4qufuh0j2lfrag98eepfiebjk3dg9k.apps.googleusercontent.com

# Resend (email verification OTP)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM=SuperNanny <noreply@supernanny.net>

# Firebase (for push notifications - optional)
FIREBASE_PROJECT_ID=super-nannys-1771710657
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# ─────────────────────────────────────────────────────────────
# PAYMENTS FEATURE FLAG
# Set ENABLE_PAYMENTS=true and fill Stripe keys to activate
# ─────────────────────────────────────────────────────────────
ENABLE_PAYMENTS=false
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# File Upload
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
