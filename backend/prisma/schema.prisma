generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────

enum Role {
  PARENT
  NANNY
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
}

enum BookingStatus {
  REQUESTED
  ACCEPTED
  DECLINED
  CANCELLED
  IN_PROGRESS
  COMPLETED
}

enum RecurringBookingStatus {
  PENDING    // waiting for nanny approval
  ACTIVE     // actively generating bookings
  PAUSED     // temporarily paused
  CANCELLED
  ENDED
}

enum DocumentType {
  ID_CARD
  ID_APPENDIX
  POLICE_CHECK
  POLICE_CLEARANCE
  FIRST_AID_CERT
  CHILDCARE_CERT
  OTHER
}

enum Badge {
  VERIFIED
  FIRST_AID
  EXPERIENCE_5_PLUS
  TOP_RATED
  FAST_RESPONDER
  BACKGROUND_CHECKED
}

// ─── Models ───────────────────────────────────────────────

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String?
  fullName     String
  phone        String?      @unique
  idNumber     String?      @unique  // Israeli ID number
  dateOfBirth  DateTime?
  avatarUrl    String?
  role         Role         @default(PARENT)
  authProvider AuthProvider @default(LOCAL)
  googleSub    String?      @unique
  isActive     Boolean      @default(true)
  isVerified   Boolean      @default(false)
  deletedAt        DateTime?
  deletedByAdminId String?        // null = self-deleted, set = admin-deleted
  preDeleteName    String?        // original fullName before soft-delete anonymization
  preDeleteEmail   String?        // original email before soft-delete anonymization
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // ── Structured address ─────────────────────────────────
  city            String  @default("")
  streetName      String  @default("")
  houseNumber     String  @default("")
  postalCode      String  @default("")
  apartmentFloor  String?
  latitude        Float?
  longitude       Float?

  // ── Phone verification ─────────────────────────────────
  phoneVerified   Boolean @default(false)

  // ── Online presence ────────────────────────────────────
  isOnline        Boolean  @default(false)
  lastSeenAt      DateTime?

  nannyProfile    NannyProfile?
  parentBookings          Booking[]           @relation("ParentBookings")
  nannyBookings           Booking[]           @relation("NannyBookings")
  parentRecurringBookings RecurringBooking[]  @relation("ParentRecurring")
  nannyRecurringBookings  RecurringBooking[]  @relation("NannyRecurring")
  sentMessages            Message[]           @relation("SentMessages")
  hiddenChats             ChatHide[]
  givenReviews            Review[]            @relation("GivenReviews")
  receivedReviews         Review[]            @relation("ReceivedReviews")
  devices                 Device[]
  paymentMethods          PaymentMethod[]
  earnings                Earning[]
  notifications           Notification[]
  favorites               Favorite[]     @relation("UserFavorites")
  favoritedBy             Favorite[]     @relation("FavoritedByUsers")
  verificationRequests    VerificationRequest[]

  @@map("users")
}

model NannyProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  headline        String   @default("")
  bio             String   @default("")
  hourlyRateNis          Int      @default(50)
  recurringHourlyRateNis Int?
  yearsExperience Int      @default(0)
  languages       String[] @default(["Hebrew"])
  skills          String[] @default([])
  badges          Badge[]  @default([])
  isVerified      Boolean  @default(false)
  isAvailable     Boolean  @default(true)
  latitude        Float?
  longitude       Float?
  city            String   @default("")
  address         String   @default("")
  rating          Float    @default(0)
  reviewsCount    Int      @default(0)
  totalEarnings   Int      @default(0)
  completedJobs   Int      @default(0)
  responseTimeMin Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // ── New fields ─────────────────────────────────────────
  minimumHoursPerBooking  Float   @default(0)     // Item 6
  allowsBabysittingAtHome Boolean @default(false)  // Item 14
  streetName              String  @default("")     // Item 7
  houseNumber             String  @default("")
  postalCode              String  @default("")
  apartmentFloor          String?

  availability     Availability[]
  dateAvailability NannyDateAvailability[]
  documents        Document[]

  @@index([city, rating])
  @@index([isAvailable, rating])
  @@map("nanny_profiles")
}

model Availability {
  id             String       @id @default(cuid())
  nannyProfileId String
  nannyProfile   NannyProfile @relation(fields: [nannyProfileId], references: [id], onDelete: Cascade)
  dayOfWeek      Int          // 0=Sunday … 6=Saturday
  fromTime       String       // "08:00"
  toTime         String       // "22:00"
  isAvailable    Boolean      @default(true)
  createdAt      DateTime     @default(now())

  @@unique([nannyProfileId, dayOfWeek, fromTime])
  @@map("availabilities")
}

model Booking {
  id              String        @id @default(cuid())
  parentUserId    String
  parent          User          @relation("ParentBookings", fields: [parentUserId], references: [id])
  nannyUserId     String
  nanny           User          @relation("NannyBookings", fields: [nannyUserId], references: [id])
  startTime       DateTime
  endTime         DateTime
  notes           String?
  status          BookingStatus @default(REQUESTED)
  hourlyRateNis   Int
  totalAmountNis  Int
  isPaid          Boolean       @default(false)
  paymentIntentId String?
  childrenCount   Int           @default(1)
  childrenAges    String[]      @default([])
  address         String?

  // ── Location type ──────────────────────────────────────
  locationType      String  @default("parent_home") // "parent_home" | "nanny_home"
  bookingCity       String?
  bookingStreet     String?
  bookingHouseNum   String?
  bookingPostalCode String?
  bookingLat        Float?
  bookingLng        Float?
  estimatedPriceNis Int?

  // ── Recurring link ────────────────────────────────────
  recurringBookingId String?
  recurringBooking   RecurringBooking? @relation(fields: [recurringBookingId], references: [id])
  isRecurring        Boolean           @default(false)
  occurrenceDate     DateTime?         // the specific day this occurrence covers

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // ── Live session fields ─────────────────────────────────
  parentConfirmedStart Boolean   @default(false)
  nannyConfirmedStart  Boolean   @default(false)
  actualStartTime      DateTime?
  actualEndTime        DateTime?
  parentConfirmedEnd   Boolean   @default(false)
  nannyConfirmedEnd    Boolean   @default(false)
  actualDurationMin    Int?
  finalAmountNis       Int?
  overtimeAmountNis    Int       @default(0)

  messages Message[]
  review   Review?
  earning  Earning?

  // ── Performance indexes ──────────────────────────────────
  @@index([parentUserId, createdAt])
  @@index([nannyUserId, createdAt])
  @@index([nannyUserId, status, startTime, endTime])
  @@index([status])
  @@index([recurringBookingId])
  @@map("bookings")
}

model Message {
  id         String   @id @default(cuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fromUserId String
  from       User     @relation("SentMessages", fields: [fromUserId], references: [id])
  text       String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([bookingId, createdAt])
  @@index([fromUserId])
  @@map("messages")
}

model ChatHide {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otherUserId String   // the user whose conversation is hidden
  createdAt   DateTime @default(now())

  @@unique([userId, otherUserId])
  @@map("chat_hides")
}

model Review {
  id             String   @id @default(cuid())
  bookingId      String   @unique
  booking        Booking  @relation(fields: [bookingId], references: [id])
  reviewerUserId String
  reviewer       User     @relation("GivenReviews", fields: [reviewerUserId], references: [id])
  revieweeUserId String
  reviewee       User     @relation("ReceivedReviews", fields: [revieweeUserId], references: [id])
  rating         Int      // 1–5
  comment        String?
  createdAt      DateTime @default(now())

  @@index([revieweeUserId])
  @@index([reviewerUserId])
  @@map("reviews")
}

model PaymentMethod {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripePaymentMethodId String?
  last4                 String?
  brand                 String?
  expiryMonth           Int?
  expiryYear            Int?
  isDefault             Boolean  @default(false)
  createdAt             DateTime @default(now())

  @@map("payment_methods")
}

model Earning {
  id           String   @id @default(cuid())
  nannyUserId  String
  nanny        User     @relation(fields: [nannyUserId], references: [id])
  bookingId    String   @unique
  booking      Booking  @relation(fields: [bookingId], references: [id])
  amountNis    Int
  platformFee  Int      @default(0)
  netAmountNis Int
  isPaid       Boolean  @default(false)
  paidAt       DateTime?
  createdAt    DateTime @default(now())

  @@index([nannyUserId, isPaid])
  @@map("earnings")
}

model Device {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fcmToken  String   @unique
  platform  String   // "ios" | "android"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("devices")
}

model Document {
  id             String       @id @default(cuid())
  nannyProfileId String
  nannyProfile   NannyProfile @relation(fields: [nannyProfileId], references: [id], onDelete: Cascade)
  type           DocumentType
  url            String
  verifiedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@map("documents")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model RecurringBooking {
  id              String                @id @default(cuid())
  parentUserId    String
  parent          User                  @relation("ParentRecurring", fields: [parentUserId], references: [id])
  nannyUserId     String
  nanny           User                  @relation("NannyRecurring", fields: [nannyUserId], references: [id])

  // ── Schedule ──────────────────────────────────────────
  daysOfWeek      Int[]                 // 0=Sun … 6=Sat
  startTime       String                // "08:00"
  endTime         String                // "17:00"
  startDate       DateTime              // when the recurring arrangement begins
  endDate         DateTime?             // null = indefinite

  // ── Pricing ───────────────────────────────────────────
  hourlyRateNis   Int                   // snapshot of recurring rate
  childrenCount   Int                   @default(1)
  childrenAges    String[]              @default([])
  address         String?
  notes           String?

  status          RecurringBookingStatus @default(PENDING)
  lastGeneratedAt DateTime?             // last date auto-generation ran up to
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  bookings        Booking[]

  @@index([parentUserId, status])
  @@index([nannyUserId, status])
  @@map("recurring_bookings")
}

model VerificationCode {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email, code])
  @@map("verification_codes")
}

model Favorite {
  id          String   @id @default(cuid())
  userId      String
  nannyUserId String
  createdAt   DateTime @default(now())

  user     User @relation("UserFavorites", fields: [userId], references: [id])
  nannyUser User @relation("FavoritedByUsers", fields: [nannyUserId], references: [id])

  @@unique([userId, nannyUserId])
  @@map("favorites")
}

// ── Date-specific availability (Item 2) ─────────────────
model NannyDateAvailability {
  id             String       @id @default(cuid())
  nannyProfileId String
  nannyProfile   NannyProfile @relation(fields: [nannyProfileId], references: [id], onDelete: Cascade)
  date           DateTime     @db.Date  // specific date
  startTime      String       // "09:00"
  endTime        String       // "17:00"
  isBlocked      Boolean      @default(false) // true = manually blocked
  createdAt      DateTime     @default(now())

  @@unique([nannyProfileId, date, startTime])
  @@index([nannyProfileId, date, isBlocked])  // date range + block lookups
  @@map("nanny_date_availability")
}

// ── Verification requests (Item 13) ─────────────────────
model VerificationRequest {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status            String   @default("pending") // pending, approved, rejected, needs_info
  idCardUrl         String?
  idAppendixUrl     String?
  policeClearanceUrl String?
  adminNotes        String?
  submittedAt       DateTime @default(now())
  reviewedAt        DateTime?
  reviewedBy        String?

  @@index([userId, status])
  @@map("verification_requests")
}
